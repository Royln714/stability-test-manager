{
  "name": "stability-test-app",
  "version": "1.0.0",
  "description": "Stability Test Result Management System",
  "scripts": {
    "dev": "concurrently --names \"server,client\" -c \"cyan,green\" \"node server.js\" \"npm run dev --prefix client\"",
    "setup": "npm install && npm install --prefix client",
    "start": "node server.js",
    "build": "npm run build --prefix client"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "archiver": "^6.0.1",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.21.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": "20.x"
  }
}
